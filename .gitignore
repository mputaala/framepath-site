# US-158 image-pipeline outputs — regenerated by sync-content.mjs on every
# build from the dev-repo screenshots + config/screenshot-allowlist.json.
# Source of truth is the dev-repo; do not commit generated assets.
/public/screenshots/manifest.json
/public/screenshots/*.avif
/public/screenshots/*.thumb.webp
/public/screenshots/hero-mac.png
/public/screenshots/hero-mac.webp
/public/screenshots/write-mac.png
/public/screenshots/write-mac.webp
/public/screenshots/plan-mac.png
/public/screenshots/plan-mac.webp
/public/screenshots/storyboard-mac.png
/public/screenshots/storyboard-mac.webp
/public/screenshots/shoot-ipad.png
/public/screenshots/shoot-ipad.webp
